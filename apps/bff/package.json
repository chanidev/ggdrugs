{
  "name": "@ggdrugs/bff",
  "version": "0.1.0",
  "private": true,
  "description": "Alle BFF — REST API, Prisma ORM, 인증/권한",
  "type": "module",
  "scripts": {
    "prisma:format": "prisma format",
    "prisma:validate": "dotenv -e ../../.env -- prisma validate",
    "prisma:generate": "dotenv -e ../../.env -- prisma generate",
    "prisma:migrate:dev": "dotenv -e ../../.env -- prisma migrate dev",
    "prisma:migrate:deploy": "dotenv -e ../../.env -- prisma migrate deploy",
    "prisma:studio": "dotenv -e ../../.env -- prisma studio",
    "dev": "dotenv -e ../../.env -- tsx watch src/server.ts",
    "start": "dotenv -e ../../.env -- node dist/server.js",
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "ingest": "dotenv -e ../../.env -- tsx src/jobs/run-ingest.ts",
    "ingest:tourapi": "dotenv -e ../../.env -- tsx src/jobs/run-ingest.ts tourapi",
    "ingest:seoul": "dotenv -e ../../.env -- tsx src/jobs/run-ingest.ts seoul-culture",
    "ingest:kcisa": "dotenv -e ../../.env -- tsx src/jobs/run-ingest.ts kcisa",
    "ingest:kcisa:backfill": "dotenv -e ../../.env -- tsx src/jobs/run-ingest.ts kcisa --kcisa-backfill --kcisa-max-pages 50",
    "ingest:tourapi:backfill": "dotenv -e ../../.env -- tsx src/jobs/run-ingest.ts tourapi 20240101 --tourapi-backfill --tourapi-max-pages 50",
    "ingest:news": "dotenv -e ../../.env -- tsx src/jobs/run-ingest.ts news-naver",
    "ingest:news:all": "dotenv -e ../../.env -- tsx src/jobs/run-ingest.ts news-naver --all",
    "ingest:news:missing": "dotenv -e ../../.env -- tsx src/jobs/run-ingest.ts news-naver --missing",
    "embed:events": "dotenv -e ../../.env -- tsx src/jobs/run-ingest.ts embed-events",
    "embed:events:all": "dotenv -e ../../.env -- tsx src/jobs/run-ingest.ts embed-events --all",
    "embed:events:missing": "dotenv -e ../../.env -- tsx src/jobs/run-ingest.ts embed-events --missing",
    "check:regions": "dotenv -e ../../.env -- tsx src/jobs/region-resolver-check.ts",
    "backfill:summary": "dotenv -e ../../.env -- tsx src/jobs/summarize-events.ts",
    "eval:summary": "dotenv -e ../../.env -- tsx src/jobs/eval-summaries.ts",
    "chat:eval": "dotenv -e ../../.env -- tsx src/jobs/chat-eval.ts",
    "community:eval": "dotenv -e ../../.env -- tsx src/jobs/community-eval.ts",
    "bench:chat-rank": "dotenv -e ../../.env -- tsx src/jobs/chat-rank-bench.ts",
    "audit:news-mappings": "dotenv -e ../../.env -- tsx src/jobs/audit-news-mappings.ts",
    "wiki:lint": "tsx src/jobs/wiki-lint.ts",
    "sweep:sessions": "dotenv -e ../../.env -- tsx src/jobs/session-sweep.ts",
    "aggregate:taste": "dotenv -e ../../.env -- tsx src/jobs/aggregate-taste-profiles.ts",
    "seed:admin": "dotenv -e ../../.env -- tsx src/jobs/seed-admin.ts",
    "mate:eval": "dotenv -e ../../.env -- tsx src/jobs/mate-eval.ts",
    "chatroom:eval": "dotenv -e ../../.env -- tsx src/jobs/chat-room-eval.ts",
    "slice5:eval": "dotenv -e ../../.env -- tsx src/jobs/slice5-eval.ts",
    "notif:eval": "dotenv -e ../../.env -- tsx src/jobs/notif-eval.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1033.0",
    "@aws-sdk/s3-request-presigner": "^3.1033.0",
    "@ggdrugs/config": "workspace:*",
    "@prisma/client": "^5.22.0",
    "@socket.io/redis-adapter": "^8.3.0",
    "express": "^5.2.1",
    "ioredis": "^5.11.0",
    "pino": "^10.3.1",
    "pino-http": "^11.0.0",
    "socket.io": "^4.8.3"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^24",
    "dotenv-cli": "^11.0.0",
    "pino-pretty": "^13.1.3",
    "prisma": "^5.22.0",
    "tsx": "^4.21.0",
    "typescript": "^5.6.3"
  }
}
