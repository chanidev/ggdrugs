# GGdrugs 환경변수 템플릿
#
# 사용법:
#   cp .env.example .env
#   그 다음 로컬 값으로 수정
#
# 주의: .env 파일은 Git에 커밋하지 않는다.
# 기술 스택 결정 내역: docs/decisions/0002-stack-decisions.md

# -------- 데이터베이스 (PostgreSQL + PostGIS) --------
POSTGRES_USER=ggdrugs
POSTGRES_PASSWORD=ggdrugs_dev
POSTGRES_DB=ggdrugs
DATABASE_URL=postgresql://ggdrugs:ggdrugs_dev@localhost:5433/ggdrugs

# -------- 벡터 DB (Qdrant) --------
QDRANT_URL=http://localhost:6333

# -------- 캐시 / 큐 (Redis — BullMQ 기반 job queue도 이 인스턴스 공유) --------
REDIS_URL=redis://localhost:6379

# -------- 오브젝트 스토리지 (MinIO, S3 호환) --------
MINIO_ROOT_USER=ggdrugs
MINIO_ROOT_PASSWORD=ggdrugs_dev_minio
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=ggdrugs
S3_SECRET_KEY=ggdrugs_dev_minio
S3_REGION=us-east-1
S3_BUCKET_APPROVAL_DOCS=ggdrugs-approval-docs
S3_BUCKET_REVIEW_PHOTOS=ggdrugs-review-photos
S3_BUCKET_EVENT_POSTERS=ggdrugs-event-posters
S3_BUCKET_USER_PHOTOS=ggdrugs-user-photos

# -------- 서비스 URL --------
BFF_URL=http://localhost:3000
LLM_SERVICE_URL=http://localhost:8000
WEB_URL=http://localhost:5173

# -------- 외부 API 키 (발급 후 입력) --------
# Kakao Maps JavaScript 키 — 브라우저 노출용 (VITE_ 접두어로 web 클라이언트에 주입)
VITE_KAKAO_MAP_JS_KEY=
# Kakao REST API 키 — 서버 전용. 지오코딩·로컬 검색 + Kakao OAuth client_id.
# 발급: https://developers.kakao.com/ → 내 애플리케이션 → 앱 키 → REST API 키
# 로그인 사용 설정 + Redirect URI 등록 필요:
#   Dev:  http://localhost:5173/api/auth/kakao/callback
KAKAO_REST_API_KEY=
# Google OAuth 2.0 Client ID/Secret — 사용자 로그인 (authorization code flow).
# 발급: https://console.cloud.google.com/ → APIs & Services → Credentials →
#       Create Credentials → OAuth client ID → Application type: "Web application"
# 허용할 Redirect URI (dev):   http://localhost:5173/api/auth/google/callback
# 허용할 Redirect URI (prod):  https://<your-domain>/api/auth/google/callback
# OAuth consent screen scope:  openid · email · profile (non-sensitive)
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=

# -------- 이벤트 데이터 소스 (배치 ingest 용) --------
# 한국관광공사 TourAPI 2.0 (공공데이터포털) — 축제 크롤 기본 소스
# 발급: https://www.data.go.kr/data/15101578/openapi.do → 활용신청 → 인증키(Encoding) 복사
TOUR_API_KEY=
# 서울열린데이터광장 "문화행사 정보" API — 서울 문화행사 포워드-루킹 커버리지
# 발급: https://data.seoul.go.kr/  (로그인 → 공공데이터 → 일반 인증키 발급)
SEOUL_OPEN_API_KEY=
# 한국문화정보원(KCISA) 공연전시정보 API_CCA_145 — 공연·전시 전국 데이터 (서울만 필터링)
# 발급: https://www.kcisa.kr/  (공공누리 > API > 공연전시정보 활용신청)
KCISA_API_KEY=
# 네이버 뉴스 검색 API — 이벤트 관련 기사 자동 매핑 (A_400 / news-naver-ingest)
# 발급: https://developers.naver.com/apps/ → 애플리케이션 등록 → 사용 API 에 "검색" 추가
NAVER_CLIENT_ID=
NAVER_CLIENT_SECRET=

# -------- LLM (OpenAI 단일 공급자, ADR 0002) --------
OPENAI_API_KEY=
OPENAI_MODEL_CHAT=gpt-4o
OPENAI_MODEL_FAST=gpt-4o-mini
OPENAI_MODEL_EMBEDDING=text-embedding-3-small

# -------- 세션 / 보안 --------
SESSION_SECRET=change-this-to-a-long-random-string-in-production
JWT_SECRET=change-this-to-a-long-random-string-in-production

# -------- 런타임 --------
NODE_ENV=development
LOG_LEVEL=debug
